{
  "manifest_version": 3,
  "name": "KAIROS — Premium SOTA Task Manager",
  "version": "1.0.0",
  "description": "A clean, premium neobrutalist browser task manager accessible via Alt+Shift+Y",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "KAIROS",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "Toggle the KAIROS overlay panel"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "index.html",
        "assets/*",
        "logo.svg",
        "icon*.png",
        "favicon.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
